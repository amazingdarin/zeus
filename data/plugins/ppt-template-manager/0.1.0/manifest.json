{
  "id": "ppt-template-manager",
  "version": "0.1.0",
  "displayName": "PPT Template Manager",
  "description": "Manage reusable PPT templates from Zeus plugin runtime.",
  "pluginApiVersion": 1,
  "engines": {
    "zeusAppBackend": ">=0.1.0",
    "zeusWeb": ">=0.1.0"
  },
  "capabilities": [
    "doc.operation.execute",
    "menu.module.mount",
    "route.module.mount"
  ],
  "frontend": {
    "entry": "frontend/index.mjs"
  },
  "backend": {
    "entry": "backend/index.mjs"
  },
  "commands": [
    {
      "id": "ppt-template-list",
      "command": "/ppt-template-list",
      "name": "列出 PPT 模版",
      "description": "列出可用的 PPT 模版",
      "category": "plugin",
      "requiresDocScope": false,
      "operationId": "list-templates"
    }
  ],
  "permissions": {
    "allowedHttpHosts": [],
    "maxExecutionMs": 8000
  },
  "contributions": {
    "operations": [
      {
        "id": "list-templates",
        "title": "List PPT Templates",
        "description": "List available PPT templates",
        "riskLevel": "low",
        "requiresDocScope": false
      }
    ],
    "menus": [
      {
        "id": "ppt-template-sidebar",
        "placement": "sidebar",
        "title": "PPT 模版",
        "order": 120,
        "route": "/plugins/ppt-template-manager/templates"
      },
      {
        "id": "ppt-template-doc-header",
        "placement": "document_header",
        "title": "PPT 模版推荐",
        "order": 120,
        "action": "list-templates"
      }
    ],
    "routes": [
      {
        "id": "ppt-template-route",
        "path": "/plugins/ppt-template-manager/templates",
        "title": "PPT 模版管理",
        "order": 120
      }
    ]
  }
}

# Optional: use S3-compatible object storage for registry image/chart data.
# Copy to `values.s3.yaml` (gitignored) and fill in real values.

persistence:
  imageChartStorage:
    type: s3
    s3:
      region: "us-east-1"
      # S3-compatible endpoint, e.g. http://rustfs.dev.svc.cluster.local:9000
      regionendpoint: "http://<s3-endpoint>"
      bucket: "<bucket>"
      accesskey: "<access_key>"
      secretkey: "<secret_key>"
      secure: false
      v4auth: true
      encrypt: false
      # Registry backend chunk size. Keep it small for low-memory environments.
      chunksize: "10m"
      rootdirectory: "/harbor"


{
  "name": "zeus",
  "private": true,
  "scripts": {
    "i18n:build": "node scripts/i18n/build-locales.mjs",
    "test:unified-editor": "node --import tsx --test apps/web/tests/save-scheduler.test.ts apps/web/tests/save-state.test.ts apps/web/tests/document-workspace-model.test.ts apps/web/tests/document-workspace-autosave.test.ts apps/web/tests/document-title-sync.test.ts apps/web/tests/document-duplicate-state.test.ts apps/web/tests/new-document-compat.test.ts apps/web/tests/general-settings-shortcuts.test.ts packages/doc-editor/tests/block-add-handle.test.ts packages/doc-editor/tests/block-placeholder.test.ts packages/doc-editor/tests/block-shortcut.test.ts packages/doc-editor/tests/block-comment-action.test.ts packages/doc-editor/tests/block-style-palette.test.ts packages/doc-editor/tests/block-style-extension.test.ts packages/doc-editor/tests/block-conversion.test.ts packages/doc-editor/tests/block-duplicate.test.ts packages/doc-editor/tests/builtin-block-content.test.ts packages/doc-editor/tests/content-sync.test.ts packages/doc-editor/tests/editable-sync.test.ts packages/doc-editor/tests/columns-transform.test.ts packages/doc-editor/tests/unsupported-plugin-block.test.ts packages/doc-editor/tests/text-enter-behavior.test.ts",
    "doctor:doc-flow": "node scripts/dev/document-flow-doctor.mjs",
    "seed:doc-flow": "node scripts/dev/document-flow-seed.mjs",
    "reset:doc-flow": "node scripts/dev/document-flow-reset.mjs",
    "eval:doc-flow:smoke": "node scripts/dev/run-playwright-harness.mjs tests/harness/document-flow/playwright/smoke-login-documents.mjs",
    "eval:doc-flow:i18n": "node scripts/dev/run-playwright-harness.mjs tests/harness/document-flow/playwright/i18n.mjs",
    "eval:doc-flow:ppt-context": "node scripts/dev/run-playwright-harness.mjs tests/harness/document-flow/playwright/ppt-context.mjs",
    "eval:doc-flow:api": "node tests/harness/document-flow/api/smoke.mjs && node tests/harness/document-flow/api/comments.mjs && node tests/harness/document-flow/api/lock.mjs",
    "eval:chat:api": "node tests/harness/chat/api/session-smoke.mjs && node tests/harness/chat/api/stream-smoke.mjs",
    "eval:chat:smoke": "node scripts/dev/run-playwright-harness.mjs tests/harness/chat/playwright/smoke.mjs",
    "eval:project-scope:api": "node tests/harness/project-scope/api/auth-smoke.mjs && node tests/harness/project-scope/api/personal-scope.mjs && node tests/harness/project-scope/api/invalid-owner.mjs",
    "doctor:repo": "node scripts/dev/repo-doctor.mjs",
    "bootstrap:repo": "node scripts/dev/repo-bootstrap.mjs",
    "test:invariants": "node --test tests/invariants/owner-scope-contract.test.mjs tests/invariants/domain-boundary-contract.test.mjs tests/invariants/docs-freshness.test.mjs"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "dependencies": {
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "tsx": "4.21.0"
  }
}

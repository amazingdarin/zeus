{
  "plugins": [
    {
      "pluginId": "ppt-plugin",
      "displayName": "PPT Plugin",
      "description": "Unified PPT agent for generating deck-style documents and final PPT tasks.",
      "tags": ["ppt", "agent", "plugin", "v2"],
      "versions": [
        {
          "version": "0.3.0",

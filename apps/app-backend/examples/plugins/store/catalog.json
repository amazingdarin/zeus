{
  "plugins": [
    {
      "pluginId": "ppt-template-manager",
      "displayName": "PPT Template Manager",
      "description": "Manage reusable PPT templates from Zeus plugin runtime.",
      "tags": ["ppt", "templates", "plugin", "v2"],
      "versions": [
        {
          "version": "0.2.0",
          "packageUrl": "/Users/darin/mine/code/zeus/apps/app-backend/examples/plugins/dist/ppt-template-manager-0.2.0.tgz",
          "manifest": {
            "id": "ppt-template-manager",
            "version": "0.2.0",
            "displayName": "PPT Template Manager",
            "description": "Manage reusable PPT templates from Zeus plugin runtime.",
            "pluginApiVersion": 2,
            "engines": {
              "zeusAppBackend": ">=0.1.0",
              "zeusWeb": ">=0.1.0"
            },
            "capabilities": [
              "system.command.register",
              "docs.tool.register",
              "ui.menu.register",
              "ui.route.register",
              "system.service.register"
            ],
            "activation": {
              "commands": ["ppt-template-manager.list-templates"],
              "routes": ["templates"],
              "tools": ["ppt-template-doc-tool"]
            },
            "frontend": {
              "entry": "frontend/index.mjs"
            },
            "backend": {
              "entry": "backend/index.mjs"
            },
            "permissions": {
              "allowedHttpHosts": [],
              "maxExecutionMs": 8000,
              "maxHookExecutionMs": 3000
            },
            "contributes": {
              "commands": [
                {
                  "id": "ppt-template-manager.list-templates",
                  "title": "列出 PPT 模版",
                  "description": "列出可用的 PPT 模版",
                  "category": "plugin",
                  "slashAliases": ["/ppt-template-list"],
                  "apiEnabled": true,
                  "requiresDocScope": false,
                  "handler": "list-templates"
                }
              ],
              "docTools": [
                {
                  "id": "ppt-template-doc-tool",
                  "placement": "documentHeader",
                  "commandId": "ppt-template-manager.list-templates",
                  "title": "PPT 模版推荐",
                  "order": 120,
                  "requiresDocScope": false
                }
              ],
              "menus": [
                {
                  "id": "ppt-template-sidebar",
                  "placement": "sidebar",
                  "title": "PPT 模版",
                  "order": 120,
                  "routeId": "templates"
                },
                {
                  "id": "ppt-template-doc-header",
                  "placement": "documentHeader",
                  "title": "PPT 模版推荐",
                  "order": 120,
                  "commandId": "ppt-template-manager.list-templates"
                }
              ],
              "routes": [
                {
                  "id": "templates",
                  "path": "/plugins/ppt-template-manager/templates",
                  "title": "PPT 模版管理",
                  "order": 120
                }
              ],
              "services": [
                {
                  "id": "ppt-template-analyzer",
                  "kind": "analyzer",
                  "commandId": "ppt-template-manager.list-templates",
                  "title": "PPT 模版分析",
                  "description": "Analyze and list reusable PPT templates"
                }
              ]
            }
          },
          "publishedAt": "2026-02-11T00:00:00Z"
        }
      ]
    }
  ]
}

# Default local dev DSN. Override in .env.local with the real cluster password.
DATABASE_URL=postgres://zeus@localhost:5432/zeus
# ENCRYPTION_KEY is intentionally unset in the committed .env.
# Set it in .env.local for persistent local secrets.

# PaddleOCR Configuration
ENABLE_PADDLE_OCR=true
PADDLE_OCR_PORT=8001

LANGFUSE_HOST=http://43.139.120.149:30300
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_ENABLED=false

# Plugin store/runtime
PLUGIN_STORE_CATALOG_FILE=/Users/darin/mine/code/zeus/apps/app-backend/examples/plugins/store/catalog.json
PLUGIN_STORE_REQUIRE_SIGNATURE=false
PLUGIN_ROOT=/Users/darin/mine/code/zeus/data/plugins

# Local-only overrides (this file is NOT loaded automatically unless you run `make run-app-backend`)
# Copy to `.env.local` and fill in real values.

# System docs directory (optional).
# If omitted, app-backend will auto-detect the repository `docs/` directory.
# SYSTEM_DOCS_DIR=/Users/darin/mine/code/zeus/docs

# PostgreSQL for local app-backend development.
# Important: this must match the database used by `server/config.local.yaml`,
# otherwise Go `/api/projects` and app-backend project-scoped APIs will read different project data.
# Example for the current local setup:
# DATABASE_URL=postgres://zeus:zeus@127.0.0.1:30432/zeus
# If you are using the k3s port-forward instead, point both server and app-backend to the same instance:
# KUBECONFIG=/Users/darin/mine/code/homeserver/secrets/kubeconfig_gz_cluster.yaml kubectl -n postgres port-forward svc/postgres 5432:5432
# Password is stored outside this repo in /Users/darin/mine/code/homeserver/secrets/postgresql_access.txt
# DATABASE_URL=postgres://zeus:<postgres-password>@localhost:5432/zeus

# Langfuse (self-hosted)
LANGFUSE_ENABLED=true
LANGFUSE_HOST=http://43.139.120.149:30300
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# MCP server (disabled by default)
MCP_SERVER_ENABLED=false
MCP_SERVER_PATH=/api/mcp
MCP_ALLOWED_ORIGINS=
MCP_REQUIRE_AUTH=true
MCP_DOC_TOOLS_READ_ENABLED=true
MCP_DOC_TOOLS_WRITE_ENABLED=false
MCP_MAX_LIMIT=50
MCP_MAX_TREE_NODES=1000

# Message center timeout monitor
MESSAGE_CENTER_TASK_TIMEOUT_MS=3600000
MESSAGE_CENTER_TIMEOUT_SWEEP_INTERVAL_MS=60000
